# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.*
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE / Editors (allow sharing workspace settings)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/*.code-snippets

.idea/*
!.idea/*.xml
!.idea/modules.xml
!.idea/runConfigurations/

*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Python cache and environment
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/

# Project-specific local artifacts / tools
*.pptx
archai-startup-session.pdf
session-ses_*.md
update_pitch.py
.antigravitycli/
# docs/
image_artifacts/
pdf-research-competitors/
.agents/
